{
  "name": "@rimora/velora",
  "version": "0.1.8",
  "description": "Official TypeScript SDK for the Velora Jobs API",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node ./scripts/patch-imports.js",
    "prepare": "pnpm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "velora",
    "cron",
    "jobs",
    "sdk",
    "scheduler"
  ],
  "author": "Velora",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velora/velora-js.git"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}
