{
  "name": "@velora/sdk",
  "version": "0.1.0",
  "description": "Lightweight TypeScript SDK for the Velora Jobs API",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "pnpm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["velora", "cron", "jobs", "sdk", "scheduler"],
  "author": "Velora",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/velora/velora-js"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}
